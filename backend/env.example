# Copy to .env and set the keys for the providers you use.
# Only the key for the selected LLM_PROVIDER is required at runtime.

# Supabase (required)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# LLM API keys — set at least one; use the one matching LLM_PROVIDER
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional: default model (overridable via UI)
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o

# With allow_credentials=True, do NOT use "*". Set to your frontend origin(s), e.g.:
# CORS_ORIGINS=https://roundtable.works,http://localhost:3000

# If you get HTTP 413 when submitting large manuscripts, increase your reverse proxy
# body limit (e.g. nginx: client_max_body_size 100M; see backend/nginx-body-size.conf).
