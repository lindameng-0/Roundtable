# ──────────────────────────────────────────
# Supabase (required)
# ──────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────
# Google OAuth 2.0 — own credentials
# Get these from https://console.cloud.google.com/apis/credentials
# ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# The redirect URI you registered in Google Cloud Console.
# Must match EXACTLY (scheme, host, path, port).
# Example values:
#   http://localhost:8000/api/auth/google/callback   (local dev)
#   https://roundtable.works/api/auth/google/callback  (production)
GOOGLE_REDIRECT_URI=

# Where the backend sends the browser after a successful login.
# This should be the URL of your React frontend.
# Example: https://roundtable.works
FRONTEND_URL=

# ──────────────────────────────────────────
# LLM API keys — set at least one
# ──────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional: override defaults
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini

# ──────────────────────────────────────────
# CORS — comma-separated frontend origins
# With allow_credentials=True, do NOT use "*"
# ──────────────────────────────────────────
# CORS_ORIGINS=https://roundtable.works,http://localhost:3000
